# PostgreSQL connection string
# Local example:
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/store_ratings
# Free cloud Postgres (Neon / Supabase) example:
# DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/store_ratings?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/store_ratings

# Secret used to sign JWT tokens - change this to any long random string
JWT_SECRET=change_this_to_a_long_random_secret_string

# Port the backend server runs on
PORT=5000

# Default admin account created by the seed script
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_ADDRESS=
